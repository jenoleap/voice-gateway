# Required: Google AI Studio / Gemini API key (NEVER put this in Expo EXPO_PUBLIC_*).
GEMINI_API_KEY=

# Live model id (no "models/" prefix). Override if Google renames preview models.
# See: https://ai.google.dev/gemini-api/docs/multimodal-live
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Server
PORT=8791
LOG_LEVEL=info

# Optional: require a valid Supabase user JWT on connect (?token= or Sec-WebSocket-Protocol)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# If unset, connections without a verified JWT are rejected when SUPABASE_* are set.
# For local dev with auth disabled, leave SUPABASE_URL empty.
