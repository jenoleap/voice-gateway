# Required: Gemini API key for THIS SERVICE ONLY (server-side — never in the Expo app).
# You may use a different key than EXPO_PUBLIC_GEMINI_API_KEY in walletx/.env (recommended for quota / rotation).
# Create a dedicated key in Google AI Studio if you want voice traffic isolated from in-app chat/marketing.
# Startup fails if empty.
GEMINI_API_KEY=

# Required: Live model id (no "models/" prefix). Startup fails if empty.
# See: https://ai.google.dev/gemini-api/docs/multimodal-live
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Required: TCP port (Railway injects this). Local: use e.g. 8791.
PORT=8791
LOG_LEVEL=info

# Optional: require a valid Supabase user JWT on connect (?token= or Sec-WebSocket-Protocol)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# If unset, connections without a verified JWT are rejected when SUPABASE_* are set.
# For local dev with auth disabled, leave SUPABASE_URL empty.
