# Required: Gemini API key for THIS SERVICE ONLY (server-side — never in the Expo app).
# In hosted environments (Railway), prefer GOOGLE_API_KEY; locally you can still use GEMINI_API_KEY.
# Create a dedicated key in Google AI Studio if you want voice traffic isolated from in-app chat/marketing.
# Startup fails if both are empty.
GOOGLE_API_KEY=
GEMINI_API_KEY=

# Required: Live model id (no "models/" prefix). Startup fails if empty.
# For Gemini 3.1 Live, use the model id currently listed in AI Studio / Live API docs.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# Optional: natural TTS voice name used by Gemini Live speechConfig.
# AI Studio examples: Zephyr, Aoide (case-sensitive).
GEMINI_LIVE_VOICE=Kore

# Optional: fallback voice when primary voice setup is unavailable.
GEMINI_LIVE_FALLBACK_VOICE=Aoide

# Required: TCP port (Railway injects this). Local: use e.g. 8791.
PORT=8791
LOG_LEVEL=info

# Optional: require a valid Supabase user JWT on connect (?token= or Sec-WebSocket-Protocol)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# If unset, connections without a verified JWT are rejected when SUPABASE_* are set.
# For local dev with auth disabled, leave SUPABASE_URL empty.
